{
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "clean": "rimraf dist dist-mv2 dist-mv3 extension-*.zip extension-*.xpi && mkdir -p dist",
    "copy-assets": "node scripts/copy-assets.mjs",
    "prebuild": "pnpm run clean && pnpm run copy-assets",
    "build:core": "pnpm --filter ./src/core run build",
    "build:design-system": "pnpm --filter ./src/design-system run build",
    "build:background": "pnpm --filter ./src/background run build",
    "build:popup": "pnpm --filter ./src/popup run build",
    "build:packages": "pnpm run build:core && pnpm run build:design-system && run-p build:background build:popup",
    "build:zip": "DIST_DIR=${DIST_DIR:-dist}; ZIP_BASENAME=${ZIP_BASENAME:-extension}; (cd \"$DIST_DIR\" && zip -r \"../${ZIP_BASENAME}-chrome.zip\" . && if [ \"${MAKE_FIREFOX:-true}\" = \"true\" ]; then zip -r \"../${ZIP_BASENAME}-firefox.xpi\" .; fi)",
    "build": "pnpm run build:packages && pnpm run build:zip",
    "build:variant": "node scripts/build-variant.mjs",
    "build:mv2": "pnpm run build:variant -- --mv=mv2",
    "build:mv3": "pnpm run build:variant -- --mv=mv3",
    "build:mv2:no-blocklist": "pnpm run build:variant -- --mv=mv2 --no-blocklist",
    "build:mv3:no-blocklist": "pnpm run build:variant -- --mv=mv3 --no-blocklist",
    "build:all": "pnpm run clean && pnpm run build:mv2 && pnpm run build:mv3",
    "build:all-variants": "pnpm run clean && pnpm run build:mv2 && pnpm run build:mv3 && pnpm run build:mv2:no-blocklist && pnpm run build:mv3:no-blocklist",
    "dev:core": "pnpm --filter ./src/core run dev",
    "dev:design-system": "pnpm --filter ./src/design-system run dev",
    "dev:background": "pnpm --filter ./src/background run dev",
    "dev:popup": "pnpm --filter ./src/popup run dev",
    "predev": "pnpm run clean && pnpm run copy-assets",
    "dev": "DIST_DIR=dist/mv3 MV_TARGET=mv3 run-p dev:*",
    "test": "run-p test:core test:background test:design-system test:popup",
    "test:core": "pnpm --filter ./src/core run test",
    "test:background": "pnpm --filter ./src/background run test",
    "test:design-system": "pnpm --filter ./src/design-system run test",
    "test:popup": "pnpm --filter ./src/popup run test",
    "test:coverage": "run-p test:core:coverage test:background:coverage test:design-system:coverage test:popup:coverage && pnpm coverage:report && pnpm coverage:badge",
    "test:core:coverage": "pnpm --filter ./src/core run test:coverage",
    "test:background:coverage": "pnpm --filter ./src/background run test:coverage",
    "test:design-system:coverage": "pnpm --filter ./src/design-system run test:coverage",
    "test:popup:coverage": "pnpm --filter ./src/popup run test:coverage",
    "coverage:report": "node scripts/coverage-report.mjs",
    "coverage:badge": "node scripts/coverage-badge.mjs",
    "storybook": "pnpm --filter ./src/popup run storybook",
    "storybook:design-system": "pnpm --filter ./src/design-system run storybook"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "3.2.4",
    "badge-maker": "^5.0.2",
    "npm-run-all": "^4.1.5",
    "prettier": "2.8.7",
    "rimraf": "^5.0.5"
  },
  "pnpm": {
    "overrides": {
      "vite@>=5.2.0 <5.2.14": ">=5.2.14",
      "esbuild@<=0.24.2": ">=0.25.0",
      "vite@>=5.0.0 <=5.4.11": ">=5.4.12",
      "vite@>=5.0.0 <5.4.15": ">=5.4.15",
      "vite@>=5.0.0 <5.4.16": ">=5.4.16",
      "vite@>=5.0.0 <5.4.18": ">=5.4.18",
      "vite@>=5.0.0 <=5.4.18": ">=5.4.19",
      "vite@>=5.0.0 <5.4.17": ">=5.4.17",
      "storybook@>=8.0.0 <8.6.15": ">=8.6.15",
      "@remix-run/router@<=1.23.1": ">=1.23.2",
      "react-router@>=6.0.0 <6.30.2": ">=6.30.2",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "diff@>=6.0.0 <8.0.3": ">=8.0.3"
    }
  }
}